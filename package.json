      "eslint-config-next",
      "tailwindcss",
      "autoprefixer",
      "postcss",
      "eslint",
      "prettier",
      "@netlify/plugin-nextjs"
    ],
    "scripts": [
      "dev",
      "build",
      "start",
      "lint",
      "lint:fix",
      "format",
      "serve",
      "type-check"
    ],
    "warning": "🚨 CRITICAL: DO NOT REMOVE OR MODIFY ABOVE DEPENDENCIES - Required for Next.js 15 TypeScript app functionality"
  },
  "scripts": {
    "dev": "next dev -p 4028",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "google:auth:refresh-token": "node --import tsx scripts/google/get-refresh-token.ts",
    "google:auth:refresh-token:gtm-edit": "node --import tsx scripts/google/get-refresh-token.ts --gtm-edit",
    "google:diff": "node --import tsx scripts/google/diff-google-state.ts",
    "google:apply:ga4-custom-dimensions": "node --import tsx scripts/google/apply-ga4-custom-dimensions.ts",
    "google:apply:gtm-outbound": "node --import tsx scripts/google/apply-gtm-outbound-layer.ts",
    "google:discover:gtm": "node --import tsx scripts/google/discover-gtm-state.ts",
    "google:discover:ga4": "node --import tsx scripts/google/discover-ga4-state.ts",
    "google:plan:gtm-outbound": "node --import tsx scripts/google/plan-gtm-outbound-layer.ts",
    "serve": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@dhiwise/component-tagger": "^1.0.14",
    "@heroicons/react": "^2.2.0",
